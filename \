package internal

import (
	"bufio"
	"io"
	"os"
	"strings"
)

// create a fuction that takes a file and returns a chanel of strings
func FilePareser(file string) (<-chan string, error) {
	filehandle, err := os.Open(file)
	if err != nil {
		return nil, err
	}

	ch := make(chan string)

	go func() {
		defer filehandle.Close()
		defer close(ch)

		scanner := bufio.NewReader(filehandle)

		replacer := strings.NewReplacer("#", "", "$", "")
		for {
			line, err := scanner.ReadString('\n')
			cleaned := replacer.Replace(line)
			if strings.Contains(cleaned, "Server") {

				parts := strings.SplitN(cleaned, " = ", 2)
				if len(parts) == 2 {
					ch <- strings.TrimSpace(parts[1])
				}

			}

			if err == io.EOF {
				break
			}

			if err != nil {
				break
			}
		}
	}()
	return ch, nil
}
